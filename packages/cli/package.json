{
  "name": "@b64/sfpm-cli",
  "description": "Salesforce package manager - CLI",
  "release": "Seedling",
  "version": "0.1.0",
  "author": "b64",
  "bin": {
    "sfpm": "./bin/run.js"
  },
  "bugs": "https://github.com/b64hub/sfpm/issues",
  "dependencies": {
    "@b64/sfpm-core": "workspace:^0.1.0",
    "@b64/sfpm-orgs": "workspace:^",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5",
    "@oclif/table": "^0.5.1",
    "@salesforce/core": "^8.25.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "fs-extra": "^11.3.3",
    "listr2": "^8.2.5",
    "object-treeify": "^5.0.1",
    "ora": "^9.0.0"
  },
  "devDependencies": {
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/fs-extra": "^11.0.4",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "chai": "^4",
    "mocha": "^10",
    "oclif": "^4",
    "shx": "^0.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json",
    "./theme.json"
  ],
  "homepage": "https://github.com/b64hub/sfpm",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "sfpm",
    "dirname": "sfpm",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "topicSeparator": " ",
    "topics": {
      "hello": {
        "description": "Say hello to the world and others"
      },
      "pool": {
        "description": "Manage scratch org pools"
      }
    },
    "theme": "theme.json"
  },
  "repository": "b64hub/sfpm",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "debug": "DEBUG=* node --inspect-brk --loader ts-node/esm --disable-warning=ExperimentalWarning bin/dev.js",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}