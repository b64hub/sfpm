{
  "name": "@b64/sfpm-hooks",
  "version": "0.1.0",
  "description": "Common hooks for Salesforce Package management",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run"
  },
  "keywords": [
    "sfpm",
    "salesforce",
    "hooks",
    "profiles",
    "typescript"
  ],
  "author": "b64",
  "license": "MIT",
  "dependencies": {
    "@b64/sfpm-core": "workspace:^0.1.0",
    "@salesforce/core": "^8.25.0",
    "fast-xml-parser": "^5.3.3"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "devDependencies": {
    "vitest": "^4.0.17"
  }
}
